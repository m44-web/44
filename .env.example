# AXE AI総務 環境変数サンプル
# このファイルをコピーして .env.local として保存し、値を入力してください。

# Slack連携（AI総務のSlackボット）
# 取得方法: company/operations/slack-app-setup.md を参照
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Anthropic Claude API
# 取得方法: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI Whisper API（議事録機能で使用）
# 取得方法: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Supabase（FAQ応答のベクトル検索で使用）
# 取得方法: https://app.supabase.com の Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
